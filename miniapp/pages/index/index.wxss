page {
  background: #0f1c34;
  color: #fff;
  padding: 20rpx;
}
.title {
  font-size: 36rpx;
  text-align: center;
  margin-bottom: 30rpx;
  color: #4fc3f7;
}
.card-wrap {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.card {
  flex: 1;
  border: 1rpx solid #4fc3f7;
  border-radius: 12rpx;
  padding: 30rpx 10rpx;
  text-align: center;
  background: rgba(79,195,247,0.1);
}
.label {
  font-size: 24rpx;
  color: #b0bec5;
}
.num {
  font-size: 40rpx;
  color: #4fc3f7;
  font-weight: bold;
}
.brand-title {
  font-size: 30rpx;
  margin: 40rpx 0 20rpx;
  color: #81d4fa;
}
.brand-item {
  padding: 16rpx;
  border-bottom: 1rpx solid #223a59;
  font-size: 28rpx;
}
.jump-btn {
  margin-top: 60rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 30rpx;
}

/* 下面是新增图表样式，适配深色主题 */
.chart-box {
  width: 100%;
  margin: 60rpx 0;
}
.chart-title {
  font-size: 34rpx;
  color: #4fc3f7;
  text-align: center;
  margin-bottom: 40rpx;
}
.chart-item {
  width: 100%;
  height: 420rpx;
  margin-bottom: 40rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}
.sub-title {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 20rpx;
  text-align: center;
}
ec-canvas {
  width: 100%;
  height: 340rpx;
}