<view class="container">
  <view class="title">异常预警列表</view>

  <view wx:if="{{alertList.length > 0}}" class="alert-list">
    <view wx:for="{{alertList}}" wx:key="id" class="alert-card">
      <view class="alert-header">
        <view class="alert-brand">{{item.brand}}</view>
        <view class="alert-level">{{item.risk_level}}</view>
      </view>
      <view class="alert-type">{{item.alert_type}}</view>
      <view class="alert-desc">{{item.desc}}</view>
      <view wx:if="{{item.data_ai_analysis}}" class="alert-analysis">AI归因：{{item.data_ai_analysis}}</view>
      <view class="alert-suggest">建议：{{item.suggest}}</view>
      <view class="alert-time">{{item.alert_time}}</view>
      <button size="mini" class="subscribe-btn" bindtap="toggleSubscribe" data-category="{{item.brand}}">
        {{item.subscribed ? '取消订阅' : '订阅品类'}}
      </button>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-title">暂无价格/舆情异常预警</view>
    <view class="empty-desc">当前暂无波动数据，请稍后再试。</view>
  </view>
</view>