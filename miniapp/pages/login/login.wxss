page {
  background: #f5f7fa;
}
.container {
  padding: 80rpx 40rpx;
}
.title {
  font-size: 44rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}
.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}
.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}
