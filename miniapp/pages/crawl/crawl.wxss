page {
  background: #f5f7fa;
}
.container {
  padding: 24rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.input {
  border: 1rpx solid #dce2ea;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 24rpx 0 12rpx;
}
.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.log-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}
.log-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.status {
  color: #0f1c34;
  font-weight: 600;
}
.log-meta {
  color: #666;
  font-size: 24rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
}
.chart-box {
  height: 420rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}
