page {
  background: #f5f7fa;
}
.container {
  padding: 24rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.filter-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}
.picker {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.card-title {
  font-weight: 600;
  margin-bottom: 8rpx;
}
.meta {
  color: #666;
  font-size: 24rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
}
.pager {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
